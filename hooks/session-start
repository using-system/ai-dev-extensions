#!/usr/bin/env bash
set -euo pipefail

# Detect platform and plugin root
if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  PLUGIN_ROOT="$CLAUDE_PLUGIN_ROOT"
  PLATFORM="claude"
elif [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  PLUGIN_ROOT="$CURSOR_PLUGIN_ROOT"
  PLATFORM="cursor"
elif [ -n "${COPILOT_CLI:-}" ]; then
  PLUGIN_ROOT="${COPILOT_PLUGIN_ROOT:-$(dirname "$(dirname "$0")")}"
  PLATFORM="copilot"
else
  PLUGIN_ROOT="$(dirname "$(dirname "$0")")"
  PLATFORM="unknown"
fi

SKILLS_DIR="$PLUGIN_ROOT/skills"

# Build skill listing
SKILL_LIST=""
if [ -d "$SKILLS_DIR" ]; then
  for skill_dir in "$SKILLS_DIR"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name=$(basename "$skill_dir")
      # Extract description from frontmatter
      description=$(sed -n '/^description:/s/^description: *"\{0,1\}\(.*\)"\{0,1\}$/\1/p' "$skill_dir/SKILL.md" | head -1)
      SKILL_LIST="$SKILL_LIST\n- $skill_name: $description"
    fi
  done
fi

CONTEXT="ai-dev-extensions skills available:${SKILL_LIST}"

# Escape for JSON
CONTEXT_ESCAPED=$(echo -e "$CONTEXT" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))')

# Output per platform
case "$PLATFORM" in
  cursor)
    echo "{\"additional_context\": $CONTEXT_ESCAPED}"
    ;;
  copilot)
    echo "{\"additionalContext\": $CONTEXT_ESCAPED}"
    ;;
  *)
    # Claude Code uses hookSpecificOutput
    echo "$CONTEXT"
    ;;
esac
